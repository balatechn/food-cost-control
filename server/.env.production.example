# Database — Neon PostgreSQL
# Get this from Neon Console → Connection Details → Connection string
DATABASE_URL=postgresql://your_user:your_password@ep-xxxxx.us-east-2.aws.neon.tech/foodcontrol?sslmode=require

# JWT
JWT_SECRET=a-strong-random-secret-at-least-32-chars
JWT_EXPIRES_IN=24h

# Client URL (your deployed frontend URL)
CLIENT_URL=https://your-frontend.vercel.app

# Environment
NODE_ENV=production
