# Database (use a cloud provider: Neon, Supabase, or Vercel Postgres)
DB_HOST=your-db-host.neon.tech
DB_PORT=5432
DB_NAME=foodcontrol
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# JWT
JWT_SECRET=a-strong-random-secret-at-least-32-chars
JWT_EXPIRES_IN=24h

# Client URL (your deployed frontend URL)
CLIENT_URL=https://your-frontend.vercel.app

# Environment
NODE_ENV=production
